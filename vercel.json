{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npx -y yarn@4.5.0 install --immutable",
  "buildCommand": "npx -y yarn@4.5.0 workspace web build",
  "outputDirectory": "web/dist",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}

{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd .. && node .yarn/releases/yarn-4.5.0.cjs install --immutable",
  "buildCommand": "cd .. && node .yarn/releases/yarn-4.5.0.cjs workspace web build",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/keeper",
      "schedule": "0 * * * *"
    }
  ]
}
